# ============================================
# Codify Project .gitignore
# Stack: .NET 10 + Angular + PostgreSQL + Docker
# ============================================


# ============================================
# OPERATING SYSTEM
# ============================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# ============================================
# EDITORS & IDEs
# ============================================

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs
*.VC.db
*.VC.VC.opendb

# Visual Studio Code (keep shared workspace settings)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.history/

# JetBrains (Rider, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Emacs
*.swp
*.swo
.project
.classpath
.settings/


# ============================================
# .NET / C# BACKEND
# ============================================

# Build output
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/
bld/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/

# NuGet
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
paket-files/
.paket/paket.exe

# Test results & coverage
TestResults/
*.trx
*.coverage
*.coveragexml
coverage*.json
coverage*.xml
coverage*.info
OpenCover/

# Profiling
*.psess
*.vsp
*.vspx
*.sap

# MSBuild
*.binlog

# Publish output
publish/
*.[Pp]ublish.xml
*.azurePubxml
*.pubxml
*.publishproj
PublishScripts/

# SQL Server local files
*.mdf
*.ldf
*.ndf

# Resharper
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user

# Rider
.localhistory/

# Fody
FodyWeavers.xsd

# Backup files from project upgrades
_UpgradeReport_Files/
Backup*/
UpgradeLog*.XML
UpgradeLog*.htm
MigrationBackup/

# Misc
*.binlog
healthchecksdb
FakesAssemblies/
.fake/
.mfractor/
.ionide/


# ============================================
# ANGULAR FRONTEND
# ============================================

# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
tmp/
out-tsc/
bazel-out/

# Angular cache
.angular/

# Sass cache
.sass-cache/

# Test & coverage
coverage/
playwright-report/
playwright/.cache/
e2e/*.js
e2e/*.map

# Misc
connect.lock
libpeerconnection.log
testem.log
typings/


# ============================================
# ENVIRONMENT & SECRETS
# ============================================

# Environment files — use .env.example as template
.env
.env.local
.env.*.local

# Local appsettings overrides (keep the base appsettings.json)
appsettings.Local.json
appsettings.Production.json

# Secrets
secrets.json
appsettings.Secrets.json

# Certificates & keys
*.key
*.pem
*.p12
*.pfx
*.cer
*.crt
jwt-key.txt
private-key.pem
public-key.pem

# Cloud credentials
.aws/
.azure/
gcloud/


# ============================================
# DATABASE
# ============================================

# PostgreSQL dumps and backups
*.dump
*.backup
pgdata/
postgres-data/

# SQLite (used in tests)
*.db
*.sqlite
*.sqlite3


# ============================================
# DOCKER
# ============================================

# Local compose overrides
docker-compose.override.yml

# Docker volumes / data directories
.docker/


# ============================================
# AI / ML
# ============================================

# Vector DB data (Chroma)
chroma_data/
vector_db/
embeddings/

# Model cache and artifacts
.cache/
models/
*.pkl
*.h5
*.pt
*.pth
*.onnx

# Jupyter (experimentation notebooks)
.ipynb_checkpoints/
*.ipynb


# ============================================
# LOGS & TEMP FILES
# ============================================

*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tmp
*.temp
*.bak
*.pid
*.pid.lock


# ============================================
# PROJECT-SPECIFIC
# ============================================

# Code execution sandbox temp files
sandbox/
temp-submissions/
execution-logs/

# User-uploaded code (stored in DB, not filesystem)
uploads/
user-code/

# Auto-generated API docs
api-docs/
swagger.json
openapi.json

# Profiling traces
*.prof
*.trace


# ============================================
# EXCEPTIONS — always keep these
# ============================================

# Keep placeholder files for empty tracked directories
!.gitkeep

# Keep base config files (not the secret overrides)
!appsettings.json
!appsettings.Development.json

# Keep environment template for onboarding
!.env.example
